    }
    
    # 建立初始解 (1=>2=>3=>4=>5=>6=>1)
    initial_solution = TspSolution(test_cities)
    
    # 執行爬山演算法 (最大代數 1000，連續失敗 100 次就停止)
    final_solution = hillClimbing(initial_solution, maxGens=1000, maxFails=100)
